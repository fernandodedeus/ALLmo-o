@page
@model ALLmoco.Pages.MealsModel

@{
    ViewData["Title"] = "Refeições";
}

<div class="container py-5" style="max-width: 700px;">

    <!-- STREAK -->

    <div class="card custom-card mb-4">

        <div class="card-body text-center">
            <!-- Streak contagem -->
            <h2 class="fw-bold mb-1">
                🔥 @Model.CurrentStreak dias seguidos
            </h2>
            <!-- Streak message, para mostrar as mensagens na tela -->
            <p class="streak-message">

                @Model.StreakMessage

            </p> 
            <!-- removida a mensagem padrao que existia aqui antes, pois após o 0.2, o streakmessage assumiu esse papel -->
        </div>

    </div>

    <!-- FORM -->

    <div class="card custom-card">

        <div class="card-body p-4">

            <h1 class="text-center fw-bold mb-4">
                🍽️ Registrar refeição
            </h1>

            <!-- METODO DE MOSTRAR NA TELA A MENSAGEM DE ERRO -->

            @if (!string.IsNullOrEmpty(Model.ErrorMessage)) 
            {
                <div class="alert custom-alert mb-4">

                    @Model.ErrorMessage

                </div>
            }

            <form method="post">

                <div class="mb-4">

                    <label class="form-label custom-label">
                        Tipo da refeição
                    </label>

                    <select class="form-select custom-input"
                            asp-for="MealCheck.MealType">

                        <option>Café da manhã</option>
                        <option>Almoço</option>
                        <option>Café da tarde</option>
                        <option>Janta</option>

                    </select>

                </div>

                <!-- CHECKBOX FIZ ESSA REF -->
                <div class="form-check mb-4">

                    <input class="form-check-input"
                           type="checkbox"
                           asp-for="MealCheck.AteMeal" />

                    <label class="form-check-label">
                        Fiz essa refeição
                    </label>

                </div>
                <!-- CHECKBOX NAO FIZ ESSA REF -->
                <div class="form-check mb-3">

                    <input class="form-check-input"
                           type="checkbox"
                           asp-for="MealCheck.DidNotEat" />

                    <label class="form-check-label">
                        Não fiz essa refeição
                    </label>

                </div>

                <div class="mb-4">

                    <label class="form-label custom-label">
                        O que você comeu? ou se NÃO comeu, diga o motivo.
                    </label>

                    <textarea class="form-control custom-input"
                              rows="4"
                              asp-for="MealCheck.Description"
                              placeholder="Ex: arroz, feijão e frango..."></textarea>

                </div>

                <button class="btn custom-button w-100">
                    Salvar refeição
                </button>

            </form>

        </div>

    </div>

    <!-- HISTÓRICO -->

    <div class="mt-5">

        <h2 class="text-center fw-bold mb-4">
            📜 Histórico
        </h2>

        @if (Model.MealHistory.Any())
        {
            <form method="post" asp-page-handler="DeleteAll"> <!-- Botao de remover historico geral -->

                <button class="btn btn-danger mb-4">

                    Limpar histórico GERAL

                </button>

            </form>

            foreach (var meal in Model.MealHistory)
            {
                <div class="card custom-card mb-3">

                    <div class="card-body">

                        <div class="d-flex justify-content-between align-items-center">

                            <h5 class="fw-bold mb-0">
                                🍽️ @meal.MealType
                            </h5>
                            <!-- Icone de feita, caso for AteMeal, marcara com feita -->
                            @if (meal.AteMeal)
                            {
                                <span class="badge bg-success">
                                    Feita
                                </span>
                            }
                            <!-- Icone de nao feita, caso ocorra de marcar a checkbox didnoteat, nao feita será marcada -->
                            @if (meal.DidNotEat)
                            {
                                <span class="badge bg-danger">
                                    Não feita
                                </span>
                            }
                            <!-- RESPONSAVEL PELO ICONE DA LIXEIRA -->
                            <form method="post"
                                  asp-page-handler="Delete"
                                  asp-route-id="@meal.Id">

                                <button type="submit"
                                        class="delete-btn">

                                    🗑️

                                </button>

                            </form>

                        </div>

                        <p class="mt-3 mb-2 text-light">
                            📝 @meal.Description
                        </p>

                        <small class="text-secondary">
                            📅 @meal.Date.ToString("dd/MM/yyyy HH:mm")
                        </small>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="text-center text-secondary">
                Nenhuma refeição registrada ainda.
            </div>
        }

    </div>

</div>